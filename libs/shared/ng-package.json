{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/libs/shared",
  "assets": [
    {
      "glob": "**/*.scss",
      "input": "src/styles",
      "output": "styles"
    },
    {
      "glob": "**/*.json",
      "input": "src/i18n",
      "output": "i18n"
    }
  ],
  "lib": {
    "entryFile": "src/index.ts"
  }
}
