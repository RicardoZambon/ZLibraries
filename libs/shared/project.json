{
  "name": "shared",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/src",
  "prefix": "shared",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": [
        "{workspaceRoot}/dist/{projectRoot}"
      ],
      "options": {
        "project": "libs/shared/ng-package.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/shared/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "libs/shared/tsconfig.lib.json",
          "watch": true
        }
      },
      "defaultConfiguration": "production",
      "dependsOn": [
        "^build"
      ]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "libs/shared/jest.config.ts"
      },
      "dependsOn": [
        "build"
      ]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4402,
        "configDir": "libs/shared/.storybook",
        "browserTarget": "storybook-host:build",
        "tsConfig": "libs/shared/.storybook/tsconfig.json",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": [
        "{options.outputDir}"
      ],
      "options": {
        "outputDir": "dist/storybook/shared",
        "configDir": "libs/shared/.storybook",
        "browserTarget": "storybook-host:build",
        "tsConfig": "libs/shared/.storybook/tsconfig.json",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c libs/shared/.storybook --url=http://localhost:4402"
      }
    },
    "static-storybook": {
      "executor": "@nx/web:file-server",
      "dependsOn": [
        "build-storybook"
      ],
      "options": {
        "buildTarget": "shared:build-storybook",
        "staticFilePath": "dist/storybook/shared",
        "spa": true
      },
      "configurations": {
        "ci": {
          "buildTarget": "shared:build-storybook:ci"
        }
      }
    }
  }
}
