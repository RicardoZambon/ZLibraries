{
  "name": "framework",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/framework/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": [
        "{workspaceRoot}/dist/{projectRoot}"
      ],
      "options": {
        "project": "libs/framework/ng-package.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/framework/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "libs/framework/tsconfig.lib.json",
          "watch": true
        }
      },
      "defaultConfiguration": "production",
      "dependsOn": [
        "^build"
      ]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "libs/framework/jest.config.ts"
      },
      "dependsOn": [
        "build"
      ]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "libs/framework/.storybook",
        "browserTarget": "storybook-host:build",
        "tsConfig": "libs/framework/.storybook/tsconfig.json",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": [
        "{options.outputDir}"
      ],
      "options": {
        "outputDir": "dist/storybook/framework",
        "configDir": "libs/framework/.storybook",
        "browserTarget": "storybook-host:build",
        "tsConfig": "libs/framework/.storybook/tsconfig.json",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c libs/framework/.storybook --url=http://localhost:4400"
      }
    },
    "static-storybook": {
      "executor": "@nx/web:file-server",
      "dependsOn": [
        "build-storybook"
      ],
      "options": {
        "buildTarget": "framework:build-storybook",
        "staticFilePath": "dist/storybook/framework",
        "spa": true
      },
      "configurations": {
        "ci": {
          "buildTarget": "framework:build-storybook:ci"
        }
      }
    }
  }
}
